{
  "manifest_version": 3,
  "name": "kust-code-claimer",
  "version": "1.2.0",
  "description": "claimer by kust bots",
  "author": "Kust",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/settings/offers*",
        "https://stake.ac/ar/settings/offers*"
      ],
      "js": ["claim.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
